# PhotoSpace Denver — environment variables
# Copy to .env.local for local dev. Never commit real secrets.

# --- Form delivery (server-side only) ---
# Without RESEND_API_KEY, form submissions are accepted and logged (not emailed),
# so the site works pre-launch. Set this in production to deliver inquiries.
RESEND_API_KEY=
# Where inquiry/estimate/membership emails are sent (defaults to the site contact email).
INQUIRY_TO_EMAIL=
# Verified Resend sender, e.g. "PhotoSpace Denver <hello@photospacedenver.com>"
INQUIRY_FROM_EMAIL=

# --- Analytics (optional; client-exposed public IDs) ---
# Any that are set get injected; leave blank to render no tracker.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Future: Stripe (membership payment) — keep secret key server-side only ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
