# PhotoSpace Denver — environment variables
# Copy to .env.local for local dev. Never commit real secrets.

# --- Form delivery (server-side only) ---
# Without RESEND_API_KEY, form submissions are accepted and logged (not emailed),
# so the site works pre-launch. Set this in production to deliver inquiries.
RESEND_API_KEY=
# Where inquiry/estimate/membership emails are sent (defaults to the site contact email).
INQUIRY_TO_EMAIL=
# Verified Resend sender, e.g. "PhotoSpace Denver <hello@photospacedenver.com>"
INQUIRY_FROM_EMAIL=

# --- Spam protection: Cloudflare Turnstile ---
# Without these, the Turnstile widget renders nothing and server verification is
# skipped, so forms still work locally. Set both to enforce in production.
# Create a widget for photospacedenver.com (+ the *.vercel.app preview domain).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- File uploads: Vercel Blob (driver's license, Certificate of Insurance) ---
# Auto-injected when a Blob store is linked to the Vercel project (Storage tab).
# Until set, the upload route returns 503 and the rest of the form still works.
BLOB_READ_WRITE_TOKEN=

# --- Payments: Stripe (replacement-value card hold on /no-insurance) ---
# Secret key is server-side only. Until set, /no-insurance shows a "not available
# yet" notice and points renters to the Certificate-of-Insurance form instead.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Analytics (optional; client-exposed public IDs) ---
# Any that are set get injected; leave blank to render no tracker.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=
